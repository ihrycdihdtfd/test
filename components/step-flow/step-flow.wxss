.step-flow { position: relative; display: flex; justify-content: space-between; padding: 42rpx 18rpx 18rpx; }
.step-flow__track { position: absolute; top: 72rpx; left: 70rpx; right: 70rpx; height: 2rpx; background: linear-gradient(90deg, transparent, rgba(212,175,55,0.26), rgba(96,165,250,0.22), rgba(212,175,55,0.26), transparent); }
.step-flow__track::after { position: absolute; top: -1rpx; left: 0; width: 34%; height: 4rpx; content: ''; background: linear-gradient(90deg, transparent, rgba(248,250,252,0.56), transparent); animation: shimmerLine 5.6s ease-in-out infinite; }
.step-flow__node { position: relative; z-index: 1; display: flex; flex: 1; flex-direction: column; align-items: center; text-align: center; }
.step-flow__orb { display: flex; align-items: center; justify-content: center; width: 64rpx; height: 64rpx; margin-bottom: 24rpx; color: var(--color-gold); font-size: 24rpx; border: 1rpx solid rgba(212,175,55,0.46); border-radius: 999rpx; background: radial-gradient(circle, rgba(212,175,55,0.16), rgba(15,23,42,0.96)); box-shadow: 0 0 34rpx rgba(212,175,55,0.14); }
.step-flow__title { color: var(--color-text-primary); font-size: 28rpx; font-weight: 650; }
.step-flow__caption { max-width: 172rpx; margin-top: 10rpx; color: var(--color-text-muted); font-size: 22rpx; line-height: 1.55; }
