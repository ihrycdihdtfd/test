.glass-card { position: relative; overflow: hidden; border: 1rpx solid var(--color-border-subtle); border-radius: var(--radius-card); background: linear-gradient(145deg, rgba(255,255,255,0.085), rgba(255,255,255,0.025)); box-shadow: var(--shadow-card); backdrop-filter: blur(24rpx); }
.glass-card::before { position: absolute; inset: 0; pointer-events: none; content: ''; border-radius: inherit; background: radial-gradient(circle at 18% 0%, rgba(212,175,55,0.16), transparent 34%), radial-gradient(circle at 84% 12%, rgba(96,165,250,0.10), transparent 28%); }
