.section-title { display: flex; flex-direction: column; align-items: center; gap: 14rpx; margin-bottom: 40rpx; text-align: center; }
.section-title__eyebrow { color: var(--color-gold-soft); font-size: 24rpx; letter-spacing: 6rpx; text-transform: uppercase; }
.section-title__title { color: var(--color-text-primary); font-size: 44rpx; font-weight: 700; letter-spacing: 1rpx; }
.section-title__caption { max-width: 560rpx; color: var(--color-text-muted); font-size: 26rpx; line-height: 1.7; }
