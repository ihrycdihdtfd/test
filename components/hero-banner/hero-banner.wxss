.hero-banner { position: relative; min-height: 1040rpx; padding: 168rpx 32rpx 96rpx; overflow: hidden; border-bottom: 1rpx solid rgba(255,255,255,0.06); background: radial-gradient(circle at 50% 28%, rgba(212,175,55,0.10), transparent 34%), radial-gradient(circle at 72% 18%, rgba(96,165,250,0.10), transparent 26%), linear-gradient(180deg, #0B1020 0%, #0F172A 58%, #0B1020 100%); }
.hero-banner::before { position: absolute; inset: 0; pointer-events: none; content: ''; opacity: 0.34; background-image: linear-gradient(rgba(255,255,255,0.035) 1rpx, transparent 1rpx), linear-gradient(90deg, rgba(255,255,255,0.025) 1rpx, transparent 1rpx); background-size: 96rpx 96rpx; mask-image: radial-gradient(circle at center, #000, transparent 76%); }
.hero-banner__glow { top: 190rpx; left: 50%; margin-left: -260rpx; }
.hero-banner__visual { position: relative; z-index: 1; margin-top: 18rpx; animation: pageFadeUp 900ms var(--ease-premium) both; }
.hero-banner__content { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; margin-top: 42rpx; text-align: center; animation: pageFadeUp 900ms var(--ease-premium) 160ms both; }
.hero-banner__eyebrow { color: var(--color-gold-soft); font-size: 22rpx; letter-spacing: 7rpx; }
.hero-banner__title { max-width: 680rpx; margin-top: 20rpx; color: var(--color-text-primary); font-size: var(--font-hero); font-weight: 760; line-height: 1.16; letter-spacing: 1rpx; text-shadow: 0 10rpx 46rpx rgba(0,0,0,0.36); }
.hero-banner__subtitle { margin-top: 22rpx; color: var(--color-text-secondary); font-size: 30rpx; line-height: 1.62; }
.hero-banner__desc { margin-top: 12rpx; color: var(--color-text-muted); font-size: 25rpx; }
.hero-banner__actions { display: flex; gap: 20rpx; justify-content: center; margin-top: 44rpx; }
@media (max-width: 360px) { .hero-banner__actions { flex-direction: column; } }
