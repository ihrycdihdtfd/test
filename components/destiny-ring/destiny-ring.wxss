.destiny-ring { position: relative; display: flex; align-items: center; justify-content: center; width: 560rpx; height: 560rpx; margin: 0 auto; }
.destiny-ring__halo { position: absolute; inset: 28rpx; border-radius: 9999rpx; background: radial-gradient(circle, rgba(212,175,55,0.22), rgba(96,165,250,0.08) 42%, transparent 68%); filter: blur(28rpx); animation: breatheGlow 6.4s ease-in-out infinite; }
.destiny-ring__outer { position: absolute; inset: 24rpx; border: 1rpx solid rgba(212,175,55,0.34); border-radius: 9999rpx; background: conic-gradient(from 90deg, transparent 0deg, rgba(212,175,55,0.24) 38deg, transparent 74deg, transparent 122deg, rgba(96,165,250,0.18) 160deg, transparent 210deg, rgba(200,169,106,0.18) 280deg, transparent 360deg); box-shadow: inset 0 0 80rpx rgba(212,175,55,0.08), 0 0 90rpx rgba(0,0,0,0.32); animation: slowRotate 48s linear infinite; }
.destiny-ring__outer::after { position: absolute; inset: 34rpx; content: ''; border: 1rpx solid rgba(255,255,255,0.10); border-radius: inherit; }
.destiny-ring__middle { position: absolute; inset: 112rpx; border: 1rpx dashed rgba(248,250,252,0.18); border-radius: 9999rpx; animation: slowRotate 72s linear reverse infinite; }
.destiny-ring__axis { position: absolute; top: 50%; left: 50%; width: 88%; height: 1rpx; background: linear-gradient(90deg, transparent, rgba(200,169,106,0.36), transparent); transform-origin: center; }
.destiny-ring__axis--a { transform: translate(-50%, -50%) rotate(0deg); }
.destiny-ring__axis--b { transform: translate(-50%, -50%) rotate(60deg); }
.destiny-ring__axis--c { transform: translate(-50%, -50%) rotate(120deg); }
.destiny-ring__mark { position: absolute; width: 14rpx; height: 14rpx; border: 1rpx solid rgba(212,175,55,0.72); border-radius: 999rpx; background: rgba(11,16,32,0.9); box-shadow: 0 0 22rpx rgba(212,175,55,0.34); }
.destiny-ring__mark--one { top: 22rpx; left: 50%; }
.destiny-ring__mark--two { right: 58rpx; top: 25%; }
.destiny-ring__mark--three { bottom: 72rpx; left: 18%; }
.destiny-ring__mark--four { right: 20%; bottom: 42rpx; }
.destiny-ring__core { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 190rpx; height: 190rpx; border: 1rpx solid rgba(212,175,55,0.38); border-radius: 9999rpx; background: radial-gradient(circle at 50% 42%, rgba(212,175,55,0.26), rgba(15,23,42,0.92) 66%); box-shadow: 0 0 60rpx rgba(212,175,55,0.18), inset 0 0 34rpx rgba(255,255,255,0.06); }
.destiny-ring__glyph { color: #F8FAFC; font-size: 68rpx; font-weight: 300; line-height: 1; }
.destiny-ring__caption { margin-top: 12rpx; color: var(--color-gold-soft); font-size: 18rpx; letter-spacing: 3rpx; }
