.fate-tag { display: inline-flex; align-items: center; justify-content: center; height: 62rpx; padding: 0 28rpx; color: var(--color-text-secondary); font-size: 25rpx; border: 1rpx solid rgba(255,255,255,0.10); border-radius: 999rpx; background: rgba(255,255,255,0.045); box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.08); }
.fate-tag::before { width: 8rpx; height: 8rpx; margin-right: 12rpx; content: ''; border-radius: 999rpx; background: var(--color-gold-soft); box-shadow: 0 0 16rpx rgba(212,175,55,0.32); }
